---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800 py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <svg class="h-6 w-6 text-brand-500" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="3" />
          <circle cx="32" cy="16" r="4" fill="currentColor" />
          <circle cx="48" cy="32" r="4" fill="currentColor" />
          <circle cx="32" cy="48" r="4" fill="currentColor" />
          <circle cx="16" cy="32" r="4" fill="currentColor" />
          <line x1="32" y1="20" x2="44" y2="32" stroke="currentColor" stroke-width="2" />
          <line x1="44" y1="32" x2="32" y2="44" stroke="currentColor" stroke-width="2" />
          <line x1="32" y1="44" x2="20" y2="32" stroke="currentColor" stroke-width="2" />
          <line x1="20" y1="32" x2="32" y2="20" stroke="currentColor" stroke-width="2" />
        </svg>
        <span class="text-lg font-bold text-brand-500">NetScope</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-4 text-sm text-slate-400">
        <span>MIT License</span>
        <span class="text-slate-600">&middot;</span>
        <a
          href="https://github.com/domenion/netscope"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-white"
        >
          GitHub
        </a>
        <span class="text-slate-600">&middot;</span>
        <span>v1.1.0</span>
      </div>
    </div>

    <p class="mt-6 text-center text-xs text-slate-500">
      &copy; {year} NetScope. Built for network engineers who prefer SSH over SNMP.
    </p>
  </div>
</footer>
