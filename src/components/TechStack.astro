---
const techs = [
  'Python 3.11+',
  'FastAPI',
  'Vue 3',
  'Cytoscape.js',
  'Tailwind CSS',
  'SQLite',
  'Scrapli',
  'Docker',
];
---

<section id="techstack" class="py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Built With</h2>
      <p class="mt-4 text-lg text-slate-400">Modern, battle-tested tools. No bloat.</p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-4">
      {techs.map((tech) => (
        <div class="rounded-lg border border-slate-700/50 bg-[#1e293b] px-5 py-3 text-sm font-medium text-slate-200 transition hover:border-brand-500/30 hover:text-white">
          {tech}
        </div>
      ))}
    </div>
  </div>
</section>
