---
---

<section id="quickstart" class="py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Get Started in 30 Seconds</h2>
      <p class="mt-4 text-lg text-slate-400">Clone, run, discover. It really is that simple.</p>
    </div>

    <div class="mx-auto max-w-2xl">
      <!-- Code block -->
      <div class="rounded-xl border border-slate-700/50 bg-[#0d1117] overflow-hidden shadow-2xl">
        <!-- Terminal header -->
        <div class="flex items-center gap-2 border-b border-slate-700/50 px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-red-500/60"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-500/60"></span>
          <span class="h-3 w-3 rounded-full bg-green-500/60"></span>
          <span class="ml-3 text-xs text-slate-500 font-mono">terminal</span>
        </div>

        <pre class="p-6 overflow-x-auto text-sm leading-relaxed font-mono"><code><span class="text-slate-500"># Clone and run</span>
<span class="text-brand-400">git</span> <span class="text-slate-200">clone https://github.com/dzpan/netscope-clean.git</span>
<span class="text-brand-400">cd</span> <span class="text-slate-200">netscope</span>
<span class="text-brand-400">docker</span> <span class="text-slate-200">compose up -d</span>

<span class="text-slate-500"># Open http://localhost:8000 — start discovering</span></code></pre>
      </div>

      <!-- Alternative install -->
      <p class="mt-6 text-center text-sm text-slate-400">
        Or install with pip:
        <code class="mx-1 rounded bg-slate-800 px-2 py-1 text-xs font-mono text-brand-400">pip install -e .</code>
        and run
        <code class="mx-1 rounded bg-slate-800 px-2 py-1 text-xs font-mono text-brand-400">uvicorn backend.main:app</code>
      </p>
    </div>
  </div>
</section>
